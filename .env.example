# Copy this file to .env and fill in your values

# SQLite (local dev):
DATABASE_URL="file:./prisma/submissions.db"

# PostgreSQL (production — e.g. Supabase, Neon, Railway):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Optional: Protect the analytics endpoint in production
# ANALYTICS_SECRET="your-long-random-secret-here"

# Google Maps — property address autocomplete + location map.
# Enable: Maps JavaScript API, Places API, Maps Embed API.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-key"

# Back-office inbox notified when a policy is bound. Leave blank to skip.
# UNDERWRITER_EMAIL="underwriting@yourcompany.com"

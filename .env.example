# Copy this file to .env and fill in your values.

# ── Database (PostgreSQL — e.g. Neon, Supabase, Railway, Azure) ──
# The schema (prisma/schema.prisma) targets PostgreSQL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────
# Generate a strong secret:  openssl rand -base64 32
NEXTAUTH_SECRET="<random-32+-char-secret>"
# IMPORTANT: in production set this to the canonical public URL. It is the primary
# defense against host-header spoofing of emailed pay/portal links — when it is a
# real non-localhost value, request Host headers are never used to build links.
NEXTAUTH_URL="http://localhost:3000"          # must match the URL you load

# ── Security / deployment hardening (optional) ────────────────
# Comma-separated allowlist of public hostnames. When set, a header-derived origin
# (only used if NEXTAUTH_URL is unset/localhost) must match one of these.
PUBLIC_HOST_ALLOWLIST=
# Number of trusted proxies in front of the app. When set, the client IP for rate
# limiting is taken as the Nth X-Forwarded-For entry from the right (un-spoofable).
TRUSTED_PROXY_HOP_COUNT=
# Demo-only switches — leave UNSET on any real deployment.
#   ALLOW_DEMO_SEED=true        seeds public demo accounts (prisma/seed.js)
#   NEXT_PUBLIC_ENABLE_DEMO=true shows one-tap demo logins on /login (build-time)
ALLOW_DEMO_SEED=
NEXT_PUBLIC_ENABLE_DEMO=

# ── OpenAI (Help Navigator + change-an-answer) ────────────────
OPENAI_API_KEY="sk-..."

# ── Google Maps — property address autocomplete + location map ─
# Enable: Maps JavaScript API, Places API, Maps Embed API, Maps Static API.
# Client-side var (NEXT_PUBLIC_) — restrict it by HTTP referrer in production.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="<your-google-maps-key>"

# ── Email ─────────────────────────────────────────────────────
# Delivery order: Resend (RESEND_API_KEY) → SMTP (below) → Ethereal test inbox.
#
# Preferred: Resend transactional API. Set the key and a verified From address.
# The From must be on a domain you've verified in Resend (or onboarding@resend.dev
# for quick testing). Reuses SMTP_FROM as the From header.
RESEND_API_KEY=
#
# Or classic SMTP. Leave SMTP_PASS blank (and RESEND_API_KEY blank) to use the
# Ethereal test inbox (preview URL in console). Gmail: use a 16-char App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=
SMTP_FROM="InsureFlow <you@gmail.com>"

# Back-office inbox notified when a policy is bound. Leave blank to skip.
UNDERWRITER_EMAIL=underwriting@yourcompany.com

# ── Stripe (real customer checkout) ───────────────────────────
# Leave STRIPE_SECRET_KEY blank to use the built-in simulated checkout.
# When set, the public pay page redirects to Stripe Checkout and the policy is
# marked paid by the webhook below. Use test keys (sk_test_…) for demos.
STRIPE_SECRET_KEY=
# Webhook signing secret. Locally, run:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
# and copy the printed "whsec_…" value here.
STRIPE_WEBHOOK_SECRET=

# ── Observability (Sentry — optional) ─────────────────────────
# Leave blank to disable (errors just go to the console). When set, server
# errors are sent to Sentry; money-path failures are tagged area=payment|
# webhook|email so you can target alert rules at them in the Sentry dashboard.
SENTRY_DSN=

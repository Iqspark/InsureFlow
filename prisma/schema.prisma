// ============================================================
// PRISMA SCHEMA — Vacant Home Insurance (Canada)
// ============================================================
// Database: PostgreSQL (Neon). Update DATABASE_URL in .env for local dev.
//
// After any schema change run:
//   npx prisma migrate dev --name <description>
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Broker (authenticated users) ────────────────────────────
model Broker {
  id         String       @id @default(cuid())
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  name       String
  email      String       @unique
  password   String       // bcrypt hash
  licenseId  String?
  role       String       @default("BROKER") // "ADMIN" | "BROKER" | "UNDERWRITER"
  active     Boolean      @default(true)

  submissions         Submission[]
  reviewedSubmissions Submission[] @relation("ReviewedBy")

  @@index([email])
}

// ── Submission (quote / policy) ──────────────────────────────
model Submission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Broker who created this quote ────────────────────────
  brokerId   String?
  broker     Broker?  @relation(fields: [brokerId], references: [id])
  policyType String   @default("Vacant Home Insurance")

  // ── Contact info ─────────────────────────────────────────
  applicantName String?
  contactEmail  String?
  contactPhone  String?
  sessionId     String?

  // ── Property location ────────────────────────────────────
  province        String?
  propertyAddress String?
  propertyType    String?

  // ── Property details ─────────────────────────────────────
  yearBuilt     Int?
  squareFootage Int?
  propertyValue Float?

  // ── Coverage choices ─────────────────────────────────────
  coveragePercent String?
  deductible      Float?

  // ── Vacancy ──────────────────────────────────────────────
  vacancyDuration String?
  vacancyReason   String?

  // ── Property management ──────────────────────────────────
  inspectionFrequency String?
  utilitiesWinterized String?
  securityFeatures    String?

  // ── Property features ────────────────────────────────────
  hasPool    String?  // "yes" | "no"
  poolFenced String?  // "yes" | "no"

  // ── Loss history ─────────────────────────────────────────
  priorDamage    String?  // "yes" | "no"
  damageType     String?
  priorClaims    String?  // "0" | "1" | "2" | "3+"
  priorInsurance String?  // "yes" | "no"

  // ── Draft / complete status ──────────────────────────────
  status     String  @default("complete") // "draft" | "complete"

  // ── Soft delete (preserves the row + audit trail) ────────
  deletedAt  DateTime?

  // ── Proposal e-signature (broker/commercial flow, Phase A) ──
  // quoted → awaiting_signature → signed → bound (Phase B) → …
  coverageStatus         String   @default("quoted")
  proposalToken          String?  @unique // public capability URL for the sign page
  proposalTokenExpiresAt DateTime?
  signedAt               DateTime?
  signatures             PolicySignature[]

  // ── Purchase state ───────────────────────────────────────
  // false = quote only · true = bound policy (Buy This Policy pressed)
  purchased  Boolean @default(false)

  // ── Payment state (simulated checkout, runs after binding) ──
  paymentStatus String   @default("unpaid") // "unpaid" | "paid"
  paidAt        DateTime?
  paidAmount    Float?
  paymentToken  String?  @unique // emailed to the applicant as a public pay link
  paymentTokenExpiresAt DateTime? // public pay/portal link expiry; null = legacy (no expiry)

  // ── Stripe (real checkout — used when STRIPE_SECRET_KEY is set) ──
  stripeSessionId       String?  @unique // Checkout Session id
  stripePaymentIntentId String?         // PaymentIntent id (audit)
  stripeStatus          String?         // last Stripe payment status
  // (WebhookEvent model below records processed Stripe event ids for dedup)

  // ── Policy term (set on bind; 12-month annual term) ─────────
  effectiveAt   DateTime?
  expiresAt     DateTime?

  // ── Cancellation (mid-term) ─────────────────────────────────
  cancelledAt   DateTime?
  cancelReason  String?

  // ── Mid-term adjustments (JSON log of MTA records) ──────────
  adjustments   String?  @default("[]")

  // ── Underwriter review audit ─────────────────────────────
  reviewedById String?
  reviewedBy   Broker?  @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  reviewNote   String?

  // ── Lifecycle audit trail ────────────────────────────────
  auditEvents  AuditEvent[]

  // ── All raw answers (JSON) ───────────────────────────────
  allAnswers String  @default("{}") // JSON — Record<string, Answer>

  // ── Underwriting result ──────────────────────────────────
  decision        String?  // "accept" | "decline" | "refer" — null for drafts
  annualPremium   Float?
  monthlyPremium  Float?
  coverageAmount  Float?
  declineReasons  String? // JSON array of strings
  referralReasons String? // JSON array of strings

  // ── Indexes for analytics queries ───────────────────────
  @@index([createdAt])
  @@index([status])
  @@index([decision])
  @@index([province])
  @@index([contactEmail])
  @@index([vacancyDuration])
  @@index([propertyType])
  @@index([brokerId])
  @@index([reviewedById])
  @@index([expiresAt])
  @@index([deletedAt])
}

// Records each Stripe webhook event id we've processed, so a redelivered or
// replayed event is handled at most once (defense-in-depth on top of the
// idempotent finalizer).
model WebhookEvent {
  id         String   @id // Stripe event id, e.g. "evt_..."
  type       String
  receivedAt DateTime @default(now())
}

// Captured proposal e-signature — the non-repudiation record. Binds the signer to
// the exact proposal they reviewed via documentHash + declarationVersion.
model PolicySignature {
  id            String     @id @default(cuid())
  submissionId  String
  submission    Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  signerName    String
  method        String     // "typed" | "drawn"
  signatureRef  String     // typed name, or stored signature reference
  declarationVersion String
  documentHash  String     // SHA-256 of the exact proposal facts the signer accepted
  ip            String?
  userAgent     String?
  signedAt      DateTime   @default(now())

  @@index([submissionId])
}

// Append-only lifecycle log: who did what to a submission, and when.
model AuditEvent {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  action       String     // "bound" | "payment_link_resent" | "paid" | "adjusted" | "cancelled" | "reviewed"
  actorId      String?    // Broker id when a signed-in user acted; null for customer/system
  actorName    String?    // display-name snapshot at the time
  actorRole    String?    // "BROKER" | "ADMIN" | "UNDERWRITER" | "CUSTOMER"
  detail       String?    // human-readable summary
  createdAt    DateTime   @default(now())

  @@index([submissionId])
}

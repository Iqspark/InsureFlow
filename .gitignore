# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Next.js build output ──────────────────────────────────────
.next/
out/

# ── PWA build artifacts (generated by next-pwa at build time) ─
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map
public/swe-worker-*.js
public/swe-worker-*.js.map

# ── Deployment assembly folder (CI artifact, not source) ──────
deploy/

# ── Environment files — NEVER commit secrets ──────────────────
.env
.env.local
.env.production
.env.development.local
.env.test.local
.env.production.local

# ── Cloud deploy credentials — NEVER commit ───────────────────
*.PublishSettings
*.publishsettings

# ── Screenshots / scratch images (may contain data) ───────────
docs/*.jpeg
docs/*.jpg
docs/*.png

# ── Database files ────────────────────────────────────────────
*.db
*.db-journal
*.db-wal
*.db-shm

# ── Claude Code memory (may contain project context) ──────────
.claude/

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── OS files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
